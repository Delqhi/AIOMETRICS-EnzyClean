{
  "name": "08-enzyclean-website-next",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "cf:deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf:preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf:upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "validate:gltf": "bash scripts/validate-gltf-assets.sh",
    "test:a11y": "npm run build && node ./scripts/run-a11y-check.mjs",
    "test:perf": "npm run build && node ./scripts/run-perf-budget.mjs",
    "check:headers": "node ./scripts/check-security-headers.mjs",
    "ci:release-gate": "npm run typecheck && npm run validate:gltf && npm run check:headers && npm run build"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.17.1",
    "@google/model-viewer": "^4.1.0",
    "@vercel/otel": "^2.1.1",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@types/node": "22.19.1",
    "@types/react": "19.2.4",
    "@types/react-dom": "19.2.2",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.1.6",
    "wrangler": "^4.69.0",
    "typescript": "5.9.3",
    "gltf-validator": "2.0.0-dev.3.10"
  }
}
